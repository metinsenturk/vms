# Loads env values from repo root and local VM override files.
def load_env(file_path, env_hash)
  return unless File.exist?(file_path)

  File.readlines(file_path).each do |line|
    clean = line.strip
    next if clean.empty? || clean.start_with?("#")
    next unless clean.include?("=")

    key, value = clean.split("=", 2)
    env_hash[key.strip] = value.strip
  end
end

env = {}
load_env(File.expand_path("../../.env", __dir__), env)
load_env(File.expand_path(".env", __dir__), env)

hyperv_switch = env.fetch("HYPERV_SWITCH_NAME", "Default Switch")
vm_name = env.fetch("VM_NAME", "hub-01")
vm_cpus = env.fetch("VM_CPUS", "2").to_i
vm_memory = env.fetch("VM_MEMORY", "2048").to_i
vm_box = env.fetch("UBUNTU_BOX", "bento/ubuntu-22.04")

Vagrant.configure("2") do |config|
  config.vm.define vm_name do |vm|
    vm.vm.box = vm_box
    vm.vm.hostname = vm_name

    vm.vm.network "public_network", bridge: hyperv_switch

    vm.vm.provider "hyperv" do |h|
      h.vmname = vm_name
      h.cpus = vm_cpus
      h.memory = vm_memory
      h.enable_virtualization_extensions = true
    end

    # Simple test provisioner for validating script-based provisioning.
    # run: can be "once" or "always"
    vm.vm.provision "initial-setup",
      type: "shell",
      path: "scripts/provision.sh",
      privileged: false,
      run: "once"

    vm.vm.provision "get-system-info",
      type: "shell",
      path: "scripts/vm-info.sh",
      privileged: false,
      run: "always"
  end
end
