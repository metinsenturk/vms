# Optional per-VM overrides.
# Uncomment only what needs to differ from repository root .env.

# Hyper-V virtual switch to bridge onto.
# HYPERV_SWITCH_NAME=External Virtual Switch

# Hyper-V display name and guest hostname identity.
# HYPERV_VMNAME=hub-01

# vCPU count assigned to the VM.
# HYPERV_CPUS=2

# Startup memory in MB.
# HYPERV_MEMORY=2048

# Max dynamic memory in MB. Set to nil to disable dynamic memory.
# HYPERV_MAXMEMORY=8192

# VM startup behavior on host boot: Nothing, StartIfRunning, or Start.
# HYPERV_AUTO_START_ACTION=Nothing

# VM shutdown behavior on host shutdown: ShutDown, TurnOff, or Save.
# HYPERV_AUTO_STOP_ACTION=ShutDown

# Use linked clone (differencing disk) when true.
# HYPERV_LINKED_CLONE=false

# Enable nested virtualization extensions.
# HYPERV_ENABLE_VIRT_EXTENSIONS=false

# Enable manual checkpoints.
# HYPERV_ENABLE_CHECKPOINTS=true

# Enable automatic checkpoints.
# HYPERV_ENABLE_AUTO_CHECKPOINTS=false

# Enable enhanced session mode transport.
# HYPERV_ENABLE_ENHANCED_SESSION=false

# Seconds to wait for guest IP address reporting.
# HYPERV_IP_ADDRESS_TIMEOUT=120

# Optional fixed MAC address for deterministic DHCP leases.
# HYPERV_MAC=

# Optional VLAN ID. Use 0 to leave VLAN unconfigured.
# HYPERV_VLAN_ID=0

# Integration services toggles (all default to true).
# HYPERV_SVC_GUEST_SERVICE_INTERFACE=true
# HYPERV_SVC_HEARTBEAT=true
# HYPERV_SVC_KVP_EXCHANGE=true
# HYPERV_SVC_SHUTDOWN=true
# HYPERV_SVC_TIME_SYNC=true
# HYPERV_SVC_VSS=true

# Base box image.
# UBUNTU_BOX=generic/ubuntu2204
