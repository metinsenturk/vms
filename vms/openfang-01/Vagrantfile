Vagrant.configure("2") do |config|
  config.vm.define "openfang-01" do |vm|
    vm.vm.box = "generic/ubuntu2204"
    vm.vm.hostname = "openfang-01"

    vm.vm.network "public_network", bridge: "External Virtual Switch"

    vm.vm.provider "hyperv" do |h|
      h.vmname = "openfang-01"
      h.cpus = 2
      h.memory = 4096
      h.maxmemory = 4096
      h.auto_start_action = "Nothing"
      h.auto_stop_action = "ShutDown"
      h.linked_clone = false
      h.enable_virtualization_extensions = false
      h.enable_checkpoints = true
      h.enable_automatic_checkpoints = false
      h.enable_enhanced_session_mode = false
      h.ip_address_timeout = 300
      h.vm_integration_services = {
        guest_service_interface: true,
        heartbeat:               true,
        key_value_pair_exchange: true,
        shutdown:                true,
        time_synchronization:    true,
        vss:                     true
      }
      h.mac = "00155DAB0002"
    end

    vm.vm.provision "install-openfang",
      type: "shell",
      path: "scripts/install-openfang.sh",
      privileged: false,
      run: "once"

    vm.vm.provision "setup-nginx",
      type: "shell",
      path: "scripts/setup-nginx.sh",
      privileged: false,
      run: "once"

    vm.vm.provision "install-ollama",
      type: "shell",
      path: "scripts/install-ollama.sh",
      privileged: false,
      run: "once"

    vm.vm.provision "pull-model",
      type: "shell",
      path: "scripts/pull-model.sh",
      privileged: false,
      run: "once"
  end
end
